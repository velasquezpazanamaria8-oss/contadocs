generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  rol          Rol      @default(cliente)
  nombre       String?
  primer_login Boolean  @default(true)
  activo       Boolean  @default(true)
  estudio_id   String?
  empresa_id   String?
  created_at   DateTime @default(now())

  estudio      Estudio?        @relation(fields: [estudio_id], references: [id])
  empresa      EmpresaCliente? @relation(fields: [empresa_id], references: [id])
  documentos   Documento[]
}

enum Rol {
  superadmin
  contador
  cliente
}

model Estudio {
  id          String       @id @default(uuid())
  nombre      String
  ruc         String       @unique
  email_admin String
  plan        Plan         @default(basico)
  estado      Estado       @default(activo)
  vence_en    DateTime?
  created_at  DateTime     @default(now())

  usuarios    Usuario[]
  empresas    EmpresaCliente[]
  categorias  Categoria[]
}

enum Plan {
  basico
  profesional
  ilimitado
}

enum Estado {
  activo
  vencido
  suspendido
}

model EmpresaCliente {
  id           String    @id @default(uuid())
  estudio_id   String
  razon_social String
  ruc          String
  email_acceso String    @unique
  activo       Boolean   @default(true)
  created_at   DateTime  @default(now())

  estudio      Estudio   @relation(fields: [estudio_id], references: [id])
  usuarios     Usuario[]
  documentos   Documento[]
  descargas    DescargaLog[]
}

model Categoria {
  id          String     @id @default(uuid())
  estudio_id  String
  nombre      String
  icono       String     @default("file")
  color       String     @default("#E6F1FB")
  color_texto String     @default("#0C447C")
  descripcion String?
  activo      Boolean    @default(true)
  orden       Int        @default(0)
  created_at  DateTime   @default(now())

  estudio     Estudio    @relation(fields: [estudio_id], references: [id])
  documentos  Documento[]
}

model Documento {
  id           String    @id @default(uuid())
  empresa_id   String
  categoria_id String
  nombre       String
  storage_path String
  periodo      String
  tamanio      Int?
  subido_por   String
  created_at   DateTime  @default(now())

  empresa      EmpresaCliente @relation(fields: [empresa_id], references: [id])
  categoria    Categoria      @relation(fields: [categoria_id], references: [id])
  subido_por_u Usuario        @relation(fields: [subido_por], references: [id])
  descargas    DescargaLog[]
}

model DescargaLog {
  id            String    @id @default(uuid())
  documento_id  String
  empresa_id    String
  descargado_at DateTime  @default(now())

  documento     Documento      @relation(fields: [documento_id], references: [id])
  empresa       EmpresaCliente @relation(fields: [empresa_id], references: [id])
}
